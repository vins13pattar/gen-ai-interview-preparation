{
  "name": "gen-ai-interview-preparation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && NODE_ENV=production next build",
    "start": "next start",
    "lint": "eslint",
    "app:setup": "npx tsx scripts/cleanup-fts5.ts && prisma db push && npx tsx scripts/seed.ts && npx tsx scripts/migrate-fts5.ts",
    "db:push": "prisma db push",
    "db:seed": "npx tsx scripts/seed.ts",
    "db:cleanup-fts5": "npx tsx scripts/cleanup-fts5.ts",
    "db:migrate-fts5": "npx tsx scripts/migrate-fts5.ts",
    "db:reset": "rm -f local.db prisma/local.db .keyfile && pnpm run app:setup",
    "setup": "pnpm run app:setup"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@prisma/client": "^5.22.0",
    "next": "15.2.9",
    "openai": "^6.32.0",
    "prisma": "^5.22.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9",
    "eslint-config-next": "15.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
